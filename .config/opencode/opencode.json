{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "ask",
      "sudo *": "ask",
      "git status": "allow",
      "git log": "allow",
      "git diff": "allow",
      "git show": "allow",
      "git branch": "allow",
      "git remote -v": "allow",
      "git stash list": "allow"
    },
    "external_directory": "allow"
  }
}
